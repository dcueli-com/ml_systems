CLUSTER_NAME=mt_iabg_hadoop_cluster
CORE_CONF_fs_defaultFS=hdfs://namenode:9000
HDFS_CONF_dfs_replication=2
YARN_CONF_yarn_resourcemanager_hostname=resourcemanager

# JMX Exporter GLOBAL
# HADOOP_OPTS="-javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9010:/opt/jmx_exporter/jmx_config.yml"
# JMX Exporter sólo para NameNode
HDFS_NAMENODE_OPTS="-javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9010:/opt/jmx_exporter/jmx_config.yml"
# JMX Exporter sólo para DataNodes
HDFS_DATANODE_OPTS="-javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9010:/opt/jmx_exporter/jmx_config.yml"
# JMX Exporter para la gestión de recursos (YARN)
YARN_RESOURCEMANAGER_OPTS="-javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9010:/opt/jmx_exporter/jmx_config.yml"
YARN_NODEMANAGER_OPTS="-javaagent:/opt/jmx_exporter/jmx_prometheus_javaagent.jar=9010:/opt/jmx_exporter/jmx_config.yml"
